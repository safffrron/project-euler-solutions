#include <bits/stdc++.h>
#define ll long long
#define endl '\n'
using namespace std;

const int mod = 1e9 +7;

bool isPrime(ll n)
{
  for(ll i=2;i<=sqrt(n);i++)
  {
    if(n%i==0)
    {
      return false;
    }
  }
  return true;
}


void solve()
{
    ll n=1, i=0;
    while(i<=10001)
    {
        if(isPrime(n)) i++;
        n++;
    }
    n--;
    cout<<n<<endl;
    
}

int main()
{
    ios::sync_with_stdio(false);
    cin.tie(NULL);
    cout.tie(NULL);
    
    //input test cases
    int t=1;
    //cin>>t;
    while(t--)
    {
        solve();
    }
    
    return 0;
}    
